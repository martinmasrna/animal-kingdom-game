#!/usr/bin/env bash
# Convenience launcher for the Animal Kingdom CLI - no venv activation needed.
#
# Defaults to the current experimental ruleset: map_b (5x3 "Savanna Expanse") and the
# 2-actions-per-turn variant (animal_kingdom/data/two_action_config.json). Explicit
# flags win over the injected defaults (argparse keeps the last occurrence):
#
#   ./run                                  # bot vs bot, seed 0, map_b + 2-action rules
#   ./run --bots human,random --seed 7
#   ./run --map map_a --config none        # the classic 1-action rules on the old map
#   ./run --quiet
#   ./run --help
#
# All arguments are passed straight through to `python -m animal_kingdom.cli`.
set -euo pipefail

here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
py="$here/.venv/bin/python"

if [[ ! -x "$py" ]]; then
  echo "No virtualenv at $here/.venv — create it first:" >&2
  echo "  python3 -m venv .venv && .venv/bin/pip install -e '.[dev,cli]'" >&2
  exit 1
fi

exec "$py" -m animal_kingdom.cli \
  --map map_b --config "$here/animal_kingdom/data/two_action_config.json" "$@"
