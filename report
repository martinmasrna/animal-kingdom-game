#!/usr/bin/env bash
# Convenience launcher for the per-card balance report - no venv activation needed.
#
#   ./report 500                           # 7x7 round-robin, 500 games/matchup
#   ./report 200 --bots random,random --jobs 4
#   ./report --help
#
# All arguments are passed straight through to `python -m animal_kingdom.sim.report`.
set -euo pipefail

here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
py="$here/.venv/bin/python"

if [[ ! -x "$py" ]]; then
  echo "No virtualenv at $here/.venv — create it first:" >&2
  echo "  python3 -m venv .venv && .venv/bin/pip install -e '.[dev]'" >&2
  exit 1
fi

exec "$py" -m animal_kingdom.sim.report "$@"
