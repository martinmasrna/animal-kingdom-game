#!/usr/bin/env bash
# Convenience launcher for the per-card balance report - no venv activation needed.
#
# Defaults to the current experimental ruleset: map_b (5x3 "Savanna Expanse") and the
# 2-actions-per-turn variant (animal_kingdom/data/two_action_config.json). Explicit
# flags win over the injected defaults (argparse keeps the last occurrence):
#
#   ./report 500                           # 7x7 round-robin, 500 games/matchup
#   ./report 500 --deck aggro              # only aggro_hq_rush's matchups + card table
#   ./report 200 --bots random,random --jobs 4
#   ./report 500 --map map_a --config none # the classic 1-action rules on the old map
#   ./report --help
#
# All arguments are passed straight through to `python -m animal_kingdom.sim.report`.
set -euo pipefail

here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
py="$here/.venv/bin/python"

if [[ ! -x "$py" ]]; then
  echo "No virtualenv at $here/.venv — create it first:" >&2
  echo "  python3 -m venv .venv && .venv/bin/pip install -e '.[dev]'" >&2
  exit 1
fi

exec "$py" -m animal_kingdom.sim.report \
  --map map_b --config "$here/animal_kingdom/data/two_action_config.json" "$@"
