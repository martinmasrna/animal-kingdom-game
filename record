#!/usr/bin/env bash
# Launch the persistent human benchmark recorder from the project virtualenv.
set -euo pipefail

here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
py="$here/.venv/bin/python"

if [[ ! -x "$py" ]]; then
  echo "No virtualenv at $here/.venv — create it first:" >&2
  echo "  python3 -m venv .venv && .venv/bin/pip install -e '.[dev,tui]'" >&2
  exit 1
fi

exec "$py" -m animal_kingdom.tui "$@"
